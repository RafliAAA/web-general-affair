datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  ADMIN
}

model User {
  user_id   String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  loans Loan[] 
  profile Profile?
}

model Profile {
  profile_id String   @id @default(uuid())
  user_id    String   @unique
  name        String?
  foto_profil String? 
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
}

model Asset {
  asset_id      String   @id @default(uuid())
  serial_number String   @unique
  asset_name    String
  asset_type    String
  status        String   @default("available")
  location      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  loan Loan[]
  
  @@index([status])
}

model Project {
  project_id  String @id @default(uuid())
  project_name String
  start_date   DateTime
  end_date     DateTime
  status  String @default("ongoing")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

}

model Loan {
  loan_id     String   @id @default(uuid())
  user_id     String
  asset_id    String
  loan_date   DateTime @default(now())
  status      String   @default("pending") // pending, approved, rejected
  approved_by String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User  @relation(fields: [user_id], references: [user_id])
  asset Asset @relation(fields: [asset_id], references: [asset_id])

  returns Return[]
}


model Return {
  return_id    String   @id @default(uuid())
  loan_id      String
  return_date  DateTime @default(now())
  condition    String
  notes        String?
  approved_by  String?
  createdAt    DateTime @default(now())

  loan Loan @relation(fields: [loan_id], references: [loan_id])

  @@index([loan_id])
}



