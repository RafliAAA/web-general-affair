datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  user_id   String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Asset {
  asset_id      String   @id @default(uuid())
  serial_number String   @unique
  asset_name    String
  asset_type    String
  status        String   @default("available")
  location      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Project {
  project_id  String @id @default(uuid())
  project_name String
  start_date   DateTime
  end_date     DateTime
  status  String @default("Sedang berjalan")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Loan {
  loan_id     String   @id @default(uuid())
  user_id     String
  asset_id    String
  project_id  String
  loan_date   DateTime @default(now())
  return_date DateTime?
  status      String   @default("dipinjam")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([user_id])
  @@index([asset_id])
  @@index([project_id])
}

