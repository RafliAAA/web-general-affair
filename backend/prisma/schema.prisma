datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum AssetStatus {
  Tersedia
  Dipinjam
  Diperbaiki
}

enum AssetCondition {
  Baik
  Cukup
  Rusak
}

enum HandoverStatus {
  Aktif       
  Dikembalikan 
}

enum BorrowStatus {
  Menunggu
  Disetujui
  Ditolak
  Dibatalkan
  Dikembalikan
}

enum MaintenanceStatus {
  MenungguVerifikasi    
  MenungguDikerjakan    
  SedangDikerjakan      
  Selesai                
  Ditolak               
  TidakDapatDiperbaiki  
}

enum DisposalMethod {
  Jual
  Hibah
}

enum Role {
  USER
  ADMIN
  IT
}

model User {
  user_id   String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  borrows  Borrow[] 
  approvedBorrows Borrow[] @relation("BorrowApprover")
  approvedReturns Return[] @relation("ReturnApprover") 
  reportedMaintenances Maintenance[] @relation("MaintenanceReporter")
  verifiedMaintenances Maintenance[] @relation("MaintenanceVerifier")
  handledMaintenances  Maintenance[] @relation("MaintenanceHandler")

  receivedHandovers Handover[] @relation("HandoverReceiver")
  createdHandovers  Handover[] @relation("HandoverCreator")
  returnedHandovers Handover[] @relation("HandoverReturner")

  profile Profile?
}

model Profile {
  profile_id String   @id @default(uuid())
  user_id    String   @unique
  name        String?
  foto_profil String? 
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
}

model Asset {
  asset_id      String   @id @default(uuid())
  asset_code    String   @unique
  serial_number String   @unique
  asset_name    String
  asset_type    String
  purchase_date DateTime
  warranty_date DateTime?
  photo         String?
  status        AssetStatus   @default(Tersedia)
  condition     AssetCondition @default(Baik)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  handoverItems HandoverItem[] 
  borrow Borrow[]
  disposal DisposalItem[]
  maintenances Maintenance[]
  
  
  @@index([status])
}

model Project {
  project_id   String @id @default(uuid())
  project_name String
  start_date   DateTime
  end_date     DateTime
  status       String @default("ongoing")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

}

model Procurement {
  procurement_id  String            @id @default(uuid())
  pr_number       String            @unique
  pr_date         DateTime
  print_date      DateTime
  due_date        DateTime
  end_user        String
  remarks         String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  items           ProcurementItem[]
}

model ProcurementItem {
  procurement_item_id              String      @id @default(uuid())
  procurement_id  String
  part_number     String
  description     String
  quantity        Int
  unit_of_measure String

  procurement     Procurement @relation(fields: [procurement_id], references: [procurement_id], onDelete: Cascade)
}

model Handover {
  handover_id   String         @id @default(uuid())
  user_id       String         // karyawan penerima
  created_by    String         // GA yang buat
  handover_date DateTime
  notes         String?
  status        HandoverStatus @default(Aktif)

  returned_at   DateTime?
  return_notes  String?
  returned_by   String?

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  items    HandoverItem[]
  receiver User  @relation("HandoverReceiver", fields: [user_id], references: [user_id])
  creator  User  @relation("HandoverCreator", fields: [created_by], references: [user_id])
  returner User? @relation("HandoverReturner", fields: [returned_by], references: [user_id])

  @@index([user_id])
  @@index([status])
}

model HandoverItem {
  handover_item_id String @id @default(uuid())
  handover_id      String
  asset_id         String
  notes            String?

  handover Handover @relation(fields: [handover_id], references: [handover_id], onDelete: Cascade)
  asset    Asset    @relation(fields: [asset_id], references: [asset_id])

  @@unique([handover_id, asset_id])
}

model Borrow {
  borrow_id           String   @id @default(uuid())
  user_id             String
  asset_id            String
  borrow_reason       String
  borrow_date         DateTime
  expected_return_date DateTime?
  status              BorrowStatus  @default(Menunggu)
  approved_by         String?
  createdAt           DateTime @default(now())          

  user     User     @relation(fields: [user_id], references: [user_id])
  asset    Asset    @relation(fields: [asset_id], references: [asset_id])
  approver User?    @relation("BorrowApprover", fields: [approved_by], references: [user_id])
  returns  Return[]
}

model Return {
  return_id   String   @id @default(uuid())
  borrow_id   String   @unique
  return_condition   String
  notes       String?
  approved_by String?
  return_date DateTime @default(now())
  createdAt   DateTime @default(now())

  borrow   Borrow @relation(fields: [borrow_id], references: [borrow_id])
  approver User?  @relation("ReturnApprover", fields: [approved_by], references: [user_id])

  @@index([borrow_id])
}

model Maintenance {
  maintenance_id   String            @id @default(uuid())
  asset_id         String
  reported_by      String
  description      String

  status           MaintenanceStatus @default(MenungguVerifikasi)

  verified_by      String?
  rejection_reason String?
  verified_at      DateTime?

  taken_by         String?
  taken_at         DateTime?
  resolution_notes String?
  completed_at     DateTime?

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  asset         Asset              @relation(fields: [asset_id], references: [asset_id])
  reporter      User               @relation("MaintenanceReporter", fields: [reported_by], references: [user_id])
  verifier      User?              @relation("MaintenanceVerifier", fields: [verified_by], references: [user_id])
  handler       User?              @relation("MaintenanceHandler", fields: [taken_by], references: [user_id])
  actualization ActualizationForm?

  @@index([status])
  @@index([asset_id])
}

model ActualizationForm {
  actualization_id String   @id @default(uuid())
  maintenance_id    String   @unique
  form_number       String   @unique

  user_name         String
  form_date         DateTime
  duration_minutes  Int

  description       String
  issue             String
  handling          String
  recommendation    String

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  maintenance Maintenance @relation(fields: [maintenance_id], references: [maintenance_id])

  @@index([maintenance_id])
}


model Disposal {
  disposal_id    String @id @default(uuid())

  memo_number    String @unique
  memo_date      DateTime

  subject        String
  description    String

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  items          DisposalItem[]
}

model DisposalItem {
  disposal_item_id String @id @default(uuid())
  disposal_id      String
  asset_id         String

  notes            String?
  method           DisposalMethod


  disposal Disposal @relation(fields: [disposal_id],references: [disposal_id],onDelete: Cascade)
  asset    Asset    @relation(fields: [asset_id], references: [asset_id])


  @@unique([disposal_id, asset_id])
}